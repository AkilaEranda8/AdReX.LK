# Production environment — copy to .env on the server (never commit .env)
JWT_SECRET=change-this-to-a-long-random-secret-min-32-chars
NEXT_PUBLIC_APP_URL=https://invoice.hexalyte.com
DATABASE_URL=file:/app/data/prod.db
RUN_DB_SEED=true

